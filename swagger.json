{
  "swagger": "2.0",
  "info": {
    "title": "Final Project API",
    "description": "API documentation for products and orders collections",
    "version": "1.0.0"
  },
  "host": "final-project-api-lrn7.onrender.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "paths": {
    "/products/": {
      "get": {
        "description": "Retrieve all products from the database.",
        "responses": {
          "200": {
            "description": "Products retrieved successfully"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "description": "Create a new product. All fields are required.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "name",
                "price",
                "category",
                "stock",
                "brand",
                "rating",
                "createdAt"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Laptop"
                },
                "price": {
                  "type": "number",
                  "example": 1200
                },
                "category": {
                  "type": "string",
                  "example": "Electronics"
                },
                "stock": {
                  "type": "number",
                  "example": 10
                },
                "brand": {
                  "type": "string",
                  "example": "Dell"
                },
                "rating": {
                  "type": "number",
                  "example": 4.5
                },
                "createdAt": {
                  "type": "string",
                  "example": "2025-04-03"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Product created successfully"
          },
          "400": {
            "description": "Bad Request - Missing or invalid input"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "description": "Retrieve a single product by MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the product"
          }
        ],
        "responses": {
          "200": {
            "description": "Product retrieved successfully"
          },
          "400": {
            "description": "Bad Request - Invalid product id"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "description": "Update an existing product by id. All fields are required.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the product"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "name",
                "price",
                "category",
                "stock",
                "brand",
                "rating",
                "createdAt"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Updated Laptop"
                },
                "price": {
                  "type": "number",
                  "example": 1300
                },
                "category": {
                  "type": "string",
                  "example": "Electronics"
                },
                "stock": {
                  "type": "number",
                  "example": 8
                },
                "brand": {
                  "type": "string",
                  "example": "Dell"
                },
                "rating": {
                  "type": "number",
                  "example": 4.8
                },
                "createdAt": {
                  "type": "string",
                  "example": "2025-04-03"
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Product updated successfully"
          },
          "400": {
            "description": "Bad Request - Invalid id or invalid input"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "description": "Delete a product by MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the product"
          }
        ],
        "responses": {
          "200": {
            "description": "Product deleted successfully"
          },
          "400": {
            "description": "Bad Request - Invalid product id"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/orders/": {
      "get": {
        "description": "Retrieve all orders from the database.",
        "responses": {
          "200": {
            "description": "Orders retrieved successfully"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "description": "Create a new order. All fields are required.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "productId",
                "quantity",
                "totalPrice",
                "customerName",
                "status",
                "orderDate",
                "shippingAddress"
              ],
              "properties": {
                "productId": {
                  "type": "string",
                  "example": "replace_with_product_id"
                },
                "quantity": {
                  "type": "number",
                  "example": 2
                },
                "totalPrice": {
                  "type": "number",
                  "example": 2400
                },
                "customerName": {
                  "type": "string",
                  "example": "John Doe"
                },
                "status": {
                  "type": "string",
                  "example": "pending"
                },
                "orderDate": {
                  "type": "string",
                  "example": "2025-04-03"
                },
                "shippingAddress": {
                  "type": "string",
                  "example": "123 Main Street"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Order created successfully"
          },
          "400": {
            "description": "Bad Request - Missing or invalid input"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "description": "Retrieve a single order by MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the order"
          }
        ],
        "responses": {
          "200": {
            "description": "Order retrieved successfully"
          },
          "400": {
            "description": "Bad Request - Invalid order id"
          },
          "404": {
            "description": "Order not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "description": "Update an existing order by id. All fields are required.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the order"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "productId",
                "quantity",
                "totalPrice",
                "customerName",
                "status",
                "orderDate",
                "shippingAddress"
              ],
              "properties": {
                "productId": {
                  "type": "string",
                  "example": "replace_with_product_id"
                },
                "quantity": {
                  "type": "number",
                  "example": 3
                },
                "totalPrice": {
                  "type": "number",
                  "example": 3600
                },
                "customerName": {
                  "type": "string",
                  "example": "John Doe"
                },
                "status": {
                  "type": "string",
                  "example": "shipped"
                },
                "orderDate": {
                  "type": "string",
                  "example": "2025-04-03"
                },
                "shippingAddress": {
                  "type": "string",
                  "example": "456 Another Street"
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Order updated successfully"
          },
          "400": {
            "description": "Bad Request - Invalid id or invalid input"
          },
          "404": {
            "description": "Order not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "description": "Delete an order by MongoDB ObjectId.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the order"
          }
        ],
        "responses": {
          "200": {
            "description": "Order deleted successfully"
          },
          "400": {
            "description": "Bad Request - Invalid order id"
          },
          "404": {
            "description": "Order not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}