    "/products/": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Get all products",
        "description": "Returns all products from MongoDB",
        "responses": {
          "200": {
            "description": "Products retrieved successfully"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Products"
        ],
        "summary": "Create a new product",
        "description": "Creates a new product. Authentication required.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "name",
                "price",
                "category",
                "stock",
                "brand",
                "rating",
                "createdAt"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Bluetooth Speaker"
                },
                "price": {
                  "type": "number",
                  "example": 95
                },
                "category": {
                  "type": "string",
                  "example": "Audio"
                },
                "stock": {
                  "type": "number",
                  "example": 18
                },
                "brand": {
                  "type": "string",
                  "example": "JBL"
                },
                "rating": {
                  "type": "number",
                  "example": 4.3
                },
                "createdAt": {
                  "type": "string",
                  "example": "2026-04-14"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Product created successfully"
          },
          "400": {
            "description": "Bad Request - Missing or invalid input"
          },
          "401": {
            "description": "Authentication required"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Get one product by id",
        "description": "Returns a single product by MongoDB ObjectId",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the product"
          }
        ],
        "responses": {
          "200": {
            "description": "Product retrieved successfully"
          },
          "400": {
            "description": "Bad Request - Invalid product id"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Products"
        ],
        "summary": "Update a product",
        "description": "Updates a product by id. Authentication required.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the product"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "name",
                "price",
                "category",
                "stock",
                "brand",
                "rating",
                "createdAt"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Bluetooth Speaker Plus"
                },
                "price": {
                  "type": "number",
                  "example": 110
                },
                "category": {
                  "type": "string",
                  "example": "Audio"
                },
                "stock": {
                  "type": "number",
                  "example": 16
                },
                "brand": {
                  "type": "string",
                  "example": "JBL"
                },
                "rating": {
                  "type": "number",
                  "example": 4.6
                },
                "createdAt": {
                  "type": "string",
                  "example": "2026-04-14"
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Product updated successfully"
          },
          "400": {
            "description": "Bad Request - Invalid id or invalid input"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Products"
        ],
        "summary": "Delete a product",
        "description": "Deletes a product by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ObjectId of the product"
          }
        ],
        "responses": {
          "200": {
            "description": "Product deleted successfully"
          },
          "400": {
            "description": "Bad Request - Invalid product id"
          },
          "404": {
            "description": "Product not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
