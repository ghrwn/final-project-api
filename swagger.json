    "/auth/google": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Start Google OAuth login",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Google OAuth callback",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get current logged in user",
        "responses": {
          "200": {
            "description": "OK"
